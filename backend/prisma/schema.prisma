// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/*
  Prisma relationship syntax:

  One-to-many:

  The "many" side stores the foreign key using @relation("relationship name", fields: [], references: []).
  The "one" side uses a list field (Model[]) to represent multiple related records.

  You can give a relationship a specific name (@relation("relationship name")).
  A name is only needed if the same two models have multiple different relationships.

  Many-to-many:

  A join model is needed to store foreign keys to both related models. The join model usually uses a composite
   key (@@id([field1, field2])) to prevent duplicate relationships.
*/

model User {
  id                 Int         @id @default(autoincrement())

  // References the user's ID in Supabase Auth
  authUserId         String      @unique
  email              String      @unique
  username           String      @unique
  avatarUrl          String?
  createdAt          DateTime    @default(now())
  createdItineraries Itinerary[] @relation("CreatedItineraries")
  likes              Like[]
  bookmarks          Bookmark[]
}

model Itinerary {
  id                Int        @id @default(autoincrement())
  userId            Int
  sourceItineraryId Int?
  title             String
  location          String
  description       String?
  coverImageUrl     String?
  isPublic          Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  creator           User       @relation("CreatedItineraries", fields: [userId], references: [id], onDelete: Cascade)
  likes             Like[]
  bookmarks         Bookmark[]
  sourceItinerary   Itinerary?  @relation("ForkedItinerary", fields: [sourceItineraryId], references: [id], onDelete: SetNull)
  savedCopies       Itinerary[] @relation("ForkedItinerary")
  pins              Pin[]
  stops             ItineraryStop[]

  @@index([isPublic])
}

// A Pin is either a CATALOG place (itineraryId = null — a seeded venue that exists
// independent of any trip) or an ITINERARY STOP (itineraryId set — a scheduled stop
// within one itinerary). orderInItinerary only means something for stops; catalog
// pins are unordered and use the sentinel value 0 (enforced by scripts/seedSfPlaces.js;
// user-created pins always have an itineraryId, so only the seed makes catalog pins).
model Pin {
  id                      Int       @id @default(autoincrement())
  itineraryId             Int?
  orderInItinerary        Int
  name                    String
  description             String?
  tags                    String[]
  category                String    @default("activity")
  interests               String[]
  cuisines                String[]
  diets                   String[]
  rating                  Float?
  pricePerPerson          Float
  latitude                Float
  longitude               Float
  address                 String?
  startTime               DateTime
  endTime                 DateTime
  travelTimeToNextMinutes Int?
  distanceToNextMeters    Float?
  locationImageUrl        String?
  hoursOpen               Json?
  itinerary               Itinerary? @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  stops                   ItineraryStop[]

  // Each stop has a unique position WITHIN its itinerary. This intentionally does
  // NOT constrain catalog pins: Postgres treats NULLs as distinct, so any number of
  // catalog pins (itineraryId = null, orderInItinerary = 0) coexist without colliding.
  @@unique([itineraryId, orderInItinerary])
}

model Like {
  userId      Int
  itineraryId Int
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@id([userId, itineraryId])
}

model Bookmark {
  userId      Int
  itineraryId Int
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@id([userId, itineraryId])
}

model ItineraryStop {
  id                      Int       @id @default(autoincrement())
  pinId                   Int
  itineraryId             Int
  orderInItinerary        Int
  startTime               DateTime
  endTime                 DateTime
  travelTimeToNextMinutes Int?
  distanceToNextMeters    Float?
  mealType                String?
  note                    String?
  pin                     Pin       @relation(fields: [pinId], references: [id])
  itinerary               Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@unique([itineraryId, orderInItinerary])
}
