// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/*
  Prisma relationship syntax:

  One-to-many:

  The "many" side stores the foreign key using @relation("relationship name", fields: [], references: []).
  The "one" side uses a list field (Model[]) to represent multiple related records.

  You can give a relationship a specific name (@relation("relationship name")).
  A name is only needed if the same two models have multiple different relationships.

  Many-to-many:

  A join model is needed to store foreign keys to both related models. The join model usually uses a composite
   key (@@id([field1, field2])) to prevent duplicate relationships.
*/

model User {
  id                 Int         @id @default(autoincrement())

  // References the user's ID in Supabase Auth
  authUserId         String      @unique
  email              String      @unique
  username           String      @unique
  avatarUrl          String?
  createdAt          DateTime    @default(now())
  createdItineraries Itinerary[] @relation("CreatedItineraries")
  likes              Like[]
  bookmarks          Bookmark[]
}

model Itinerary {
  id                Int               @id @default(autoincrement())
  userId            Int
  sourceItineraryId Int?
  title             String
  location          String
  description       String?
  coverImageUrl     String?
  isPublic          Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Trip-level constraints the itinerary was generated from — persisted so a
  // saved itinerary is self-describing (US #1 budget display) and editable
  // (US #7). All nullable: older rows and manually-created itineraries have none.
  // Group interests/food/diets and groupSize are NOT stored here — they derive
  // from the members relation below, so there's one source of truth (no drift).
  tripDate           DateTime?  @db.Date // calendar day; @db.Date avoids the UTC-midnight off-by-one
  dayStart           String?    // requested window start, "HH:MM"
  dayEnd             String?    // requested window end, "HH:MM" (< dayStart ⇒ overnight)
  maxBudgetPerPerson Float?     // the per-person budget cap the organizer entered
  travelRadius       Float?     // miles, radius the day was optimized within
  transport          String?    // walking | biking | transit | driving (see TRANSPORT_MODES)
  meetingPointLat    Float?     // computed geometric-median group anchor
  meetingPointLng    Float?

  creator           User              @relation("CreatedItineraries", fields: [userId], references: [id], onDelete: Cascade)
  likes             Like[]
  bookmarks         Bookmark[]
  members           ItineraryMember[]
  sourceItinerary   Itinerary?        @relation("ForkedItinerary", fields: [sourceItineraryId], references: [id], onDelete: SetNull)
  savedCopies       Itinerary[]       @relation("ForkedItinerary")
  stops             ItineraryStop[]

  // Discover default feed: WHERE isPublic ORDER BY createdAt DESC + paginate —
  // one index-ordered scan covers filter, sort, and pagination. (Replaces a bare
  // [isPublic] index, which couldn't help the createdAt sort every page pays for.)
  @@index([isPublic, createdAt])
  // scope=mine + the Created dashboard filter by owner; also backs cascade delete.
  @@index([userId])
}

// A Pin is a VENUE — a catalog place that can be used in zero or more itineraries.
// Venue-fixed attributes live here; per-visit scheduling data lives in ItineraryStop.
model Pin {
  id               Int               @id @default(autoincrement())
  name             String
  description      String?
  category         String            @default("activity")
  interests        String[]
  cuisines         String[]
  diets            String[]
  rating           Float?
  pricePerPerson   Float
  latitude         Float
  longitude        Float
  address          String?
  locationImageUrl String?
  hoursOpen        Json?
  // Provenance + AI-enrichment tracking. `source` distinguishes hand-curated
  // venues from the bulk OpenStreetMap import; `enrichedAt` is stamped when the
  // AI enrichment job fills a venue's rating/tags, so the job can target only
  // un-enriched OSM rows and stays idempotent/resumable.
  source           String?
  enrichedAt       DateTime?
  stops            ItineraryStop[]
}

model Like {
  userId      Int
  itineraryId Int
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@id([userId, itineraryId])
  // The composite PK is ordered by userId, so an itineraryId-only lookup can't
  // use it. This backs countForItinerary + the "popular" sort's like aggregation.
  @@index([itineraryId])
}

model Bookmark {
  userId      Int
  itineraryId Int
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@id([userId, itineraryId])
}

model ItineraryStop {
  id                      Int       @id @default(autoincrement())
  pinId                   Int
  itineraryId             Int
  orderInItinerary        Int
  startTime               DateTime
  endTime                 DateTime
  travelTimeToNextMinutes Int?
  distanceToNextMeters    Float?
  mealType                String?
  note                    String?
  pin                     Pin       @relation(fields: [pinId], references: [id])
  itinerary               Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@unique([itineraryId, orderInItinerary])
  // Backs the interest-filter join (stops → pin) and the ON DELETE RESTRICT check
  // on Pin. itineraryId needs no index — it's the lead column of the unique above.
  @@index([pinId])
}

// A member of the group a generated itinerary was built for. Captures the
// per-person inputs the wizard collects (name, start location, and preference
// tags) so a saved itinerary can show/edit who was in the group and what they
// wanted — not just the group-level aggregate. Cascade-deleted with the parent.
model ItineraryMember {
  id            Int       @id @default(autoincrement())
  itineraryId   Int
  name          String
  // Where this member started from. label is the human-readable address the
  // frontend's picker resolved; lat/lng are what the meeting-point math uses.
  // Nullable because a member may be added without a resolved location.
  startLabel    String?
  startLat      Float?
  startLng      Float?
  interestTags  String[]  // this member's chosen interests
  foodPrefs     String[]  // this member's food/cuisine prefs
  diets         String[]  // this member's dietary requirements
  itinerary     Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([itineraryId])
}
